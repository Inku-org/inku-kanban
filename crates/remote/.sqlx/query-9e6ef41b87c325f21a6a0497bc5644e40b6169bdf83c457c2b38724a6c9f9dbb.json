  "query": "\n        SELECT i.title, i.project_id, p.name AS project_name, ps.name AS status_name\n        FROM issues i\n        JOIN projects p ON p.id = i.project_id\n        JOIN project_statuses ps ON ps.id = i.status_id\n        WHERE i.id = $1\n        ",
